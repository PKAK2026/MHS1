<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ระบบบันทึกข้อมูลสถานะที่ราชพัสดุและพื้นที่ป่าไม้ฯ</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;600;700&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.jsdelivr.net/npm/xlsx@0.18.5/dist/xlsx.full.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>

    <style>
        body {
            font-family: 'Sarabun', sans-serif;
        }
        /* Glassmorphism Effect */
        .glass-card {
            background: rgba(255, 255, 255, 0.12);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border: 1px solid rgba(255, 255, 255, 0.2);
        }
        /* Custom Scrollbar */
        .custom-scroll::-webkit-scrollbar {
            width: 6px;
            height: 6px;
        }
        .custom-scroll::-webkit-scrollbar-track {
            background: rgba(255, 255, 255, 0.05);
            border-radius: 10px;
        }
        .custom-scroll::-webkit-scrollbar-thumb {
            background: rgba(255, 255, 255, 0.3);
            border-radius: 10px;
        }
        .custom-scroll::-webkit-scrollbar-thumb:hover {
            background: rgba(255, 255, 255, 0.5);
        }
        /* Tree Animation */
        @keyframes treeSway {
            0%, 100% { transform: rotate(0deg) scale(1); }
            50% { transform: rotate(8deg) scale(1.05); }
        }
        .animated-tree {
            display: inline-block;
            animation: treeSway 3s ease-in-out infinite;
        }
    </style>
</head>
<body class="bg-gradient-to-br from-green-950 via-green-800 to-emerald-600 min-h-screen text-white p-4 md:p-8">

    <div class="max-w-6xl mx-auto space-y-6">
        
        <header class="glass-card rounded-3xl p-6 md:p-8 shadow-2xl text-center relative overflow-hidden transition-all duration-300 hover:shadow-green-900/30">
            <div class="absolute -top-10 -left-10 w-40 h-40 bg-emerald-500/10 rounded-full blur-3xl"></div>
            <div class="absolute -bottom-10 -right-10 w-40 h-40 bg-green-400/10 rounded-full blur-3xl"></div>
            
            <h1 class="text-xl md:text-3xl font-bold tracking-wide mb-3 flex items-center justify-center gap-3">
                <i class="fa-solid fa-tree text-emerald-400 animated-tree"></i>
                <span class="bg-clip-text text-transparent bg-gradient-to-r from-white via-emerald-100 to-white">
                    ที่ราชพัสดุและพื้นที่ป่าไม้ฯ สำนักงานเขตพื้นที่การศึกษาประถมศึกษาแม่ฮ่องสอน เขต 1
                </span>
                <i class="fa-solid fa-tree text-emerald-400 animated-tree" style="animation-delay: 0.5s;"></i>
            </h1>
            
            <div class="text-base md:text-lg text-emerald-100/90 font-medium space-y-1">
                <p>สำนักงานเขตพื้นที่การศึกษา: <span id="display-office" class="text-white underline decoration-emerald-400 underline-offset-4">....................................</span></p>
                <p class="text-sm text-emerald-200/80">แอดมินผู้ดูแลระบบ: <span id="display-admin" class="text-white">....................................</span></p>
            </div>

            <div class="mt-6 pt-6 border-t border-white/10 flex flex-wrap items-center justify-between gap-4">
                <div class="flex items-center gap-2 bg-black/20 px-4 py-2 rounded-full text-sm">
                    <span class="relative flex h-3 w-3">
                        <span id="status-ping" class="animate-ping absolute inline-flex h-full w-full rounded-full bg-yellow-400 opacity-75"></span>
                        <span id="status-dot" class="relative inline-flex rounded-full h-3 w-3 bg-yellow-500"></span>
                    </span>
                    <span>สถานะระบบ: <strong id="status-text" class="text-yellow-300">กำลังโหลด...</strong></span>
                </div>
                
                <div class="flex flex-wrap gap-3">
                    <button onclick="testConnection()" class="bg-white/10 hover:bg-white/20 active:scale-95 text-white font-semibold px-4 py-2 rounded-2xl transition-all duration-200 flex items-center gap-2 text-sm border border-white/10 cursor-pointer">
                        <i class="fa-solid fa-link text-emerald-400"></i> ทดสอบการเชื่อมต่อ
                    </button>
                    <button onclick="loadData()" class="bg-emerald-500 hover:bg-emerald-400 active:scale-95 text-white font-semibold px-5 py-2 rounded-2xl transition-all duration-200 flex items-center gap-2 text-sm shadow-lg shadow-emerald-950/40 cursor-pointer">
                        <i class="fa-solid fa-cloud-arrow-down"></i> โหลดข้อมูลจาก Google Sheet
                    </button>
                    <button onclick="toggleAdminModal()" class="bg-amber-500/20 hover:bg-amber-500/40 border border-amber-500/40 text-amber-200 px-3 py-2 rounded-2xl text-sm transition-all cursor-pointer">
                        <i class="fa-solid fa-user-gear"></i> ตั้งค่าแอดมิน
                    </button>
                </div>
            </div>
        </header>

        <main class="grid grid-cols-1 lg:grid-cols-12 gap-6">
            
            <section class="lg:col-span-5 glass-card rounded-3xl p-6 shadow-2xl space-y-5">
                <h2 class="text-lg font-bold flex items-center gap-2 text-emerald-300 border-b border-white/10 pb-3">
                    <i class="fa-solid fa-pen-to-square"></i> บันทึกสถานะรื้อถอนและพื้นที่ป่า
                </h2>
                
                <form id="recordForm" onsubmit="submitForm(event)" class="space-y-4">
                    <div>
                        <label class="block text-sm font-semibold mb-2 text-emerald-100 flex items-center gap-1.5">
                            <i class="fa-solid fa-school text-emerald-400"></i> เลือกโรงเรียน
                        </label>
                        <select id="school" required class="w-full bg-black/30 border border-white/20 rounded-2xl px-4 py-3 text-white focus:outline-none focus:border-emerald-400 focus:ring-2 focus:ring-emerald-500/20 transition-all">
                            <option value="" disabled selected class="text-gray-500">-- เลือกโรงเรียน --</option>
                            <option value="ชุมชนบ้านปางหมู">ชุมชนบ้านปางหมู</option>
                            <option value="ขุนยวม">ขุนยวม</option>
                            <option value="ชุมชนต่อแพวิทยา">ชุมชนต่อแพวิทยา</option>
                            <option value="ชุมชนบ้านผาบ่อง">ชุมชนบ้านผาบ่อง</option>
                            <option value="ชุมชนบ้านเมืองปอน">ชุมชนบ้านเมืองปอน</option>
                            <option value="ชุมชนบ้านแม่ฮี้">ชุมชนบ้านแม่ฮี้</option>
                        </select>
                    </div>

                    <div>
                        <label class="block text-sm font-semibold mb-2 text-emerald-100 flex items-center gap-1.5">
                            <i class="fa-solid fa-map-location-dot text-emerald-400"></i> แปลงหมายเลขที่ มส.
                        </label>
                        <input type="number" id="parcelNo" required placeholder="ตัวเลข เช่น 526" class="w-full bg-black/30 border border-white/20 rounded-2xl px-4 py-3 text-white focus:outline-none focus:border-emerald-400 focus:ring-2 focus:ring-emerald-500/20 transition-all">
                    </div>

                    <div>
                        <label class="block text-sm font-semibold mb-2 text-emerald-100 flex items-center gap-1.5">
                            <i class="fa-solid fa-trowel-bricks text-emerald-400"></i> ลำดับอาคารที่ขอรื้อถอน (เลือกได้หลายรายการ)
                        </label>
                        <div id="buildingContainer" class="grid grid-cols-4 gap-2 max-h-36 overflow-y-auto p-3 bg-black/30 border border-white/20 rounded-2xl custom-scroll">
                            </div>
                    </div>

                    <div>
                        <label class="block text-sm font-semibold mb-2 text-emerald-100 flex items-center gap-1.5">
                            <i class="fa-solid fa-circle-info text-emerald-400"></i> รร.ส่งหนังสือรื้อถอนมาที่เขต
                        </label>
                        <div class="grid grid-cols-3 gap-2 bg-black/20 p-1.5 rounded-2xl border border-white/10">
                            <label class="cursor-pointer flex flex-col items-center justify-center p-2 rounded-xl text-xs font-semibold border border-transparent transition-all hover:bg-white/5 has-[:checked]:bg-emerald-500 has-[:checked]:text-white">
                                <input type="radio" name="status" value="✅เสร็จสิ้น" required class="hidden">
                                <span class="text-base mb-1">✅</span> เสร็จสิ้น
                            </label>
                            <label class="cursor-pointer flex flex-col items-center justify-center p-2 rounded-xl text-xs font-semibold border border-transparent transition-all hover:bg-white/5 has-[:checked]:bg-amber-500 has-[:checked]:text-white">
                                <input type="radio" name="status" value="🕒กำลังดำเนินการ" class="hidden">
                                <span class="text-base mb-1">🕒</span> กำลังดำเนินการ
                            </label>
                            <label class="cursor-pointer flex flex-col items-center justify-center p-2 rounded-xl text-xs font-semibold border border-transparent transition-all hover:bg-white/5 has-[:checked]:bg-rose-500 has-[:checked]:text-white">
                                <input type="radio" name="status" value="❌ยังไม่เสร็จสิ้น" class="hidden">
                                <span class="text-base mb-1">❌</span> ยังไม่เสร็จสิ้น
                            </label>
                        </div>
                    </div>

                    <div>
                        <label class="block text-sm font-semibold mb-2 text-emerald-100 flex items-center gap-1.5">
                            <i class="fa-solid fa-file-signature text-emerald-400"></i> เลขหนังสือจากโรงเรียน
                        </label>
                        <input type="text" id="letterNo" required value="ศธ 0415./" placeholder="ศธ 0415./..." class="w-full bg-black/30 border border-white/20 rounded-2xl px-4 py-3 text-white focus:outline-none focus:border-emerald-400 focus:ring-2 focus:ring-emerald-500/20 transition-all">
                    </div>

                    <div>
                        <label class="block text-sm font-semibold mb-2 text-emerald-100 flex items-center gap-1.5">
                            <i class="fa-solid fa-calendar-days text-emerald-400"></i> วันที่เอกสาร (ปฏิทิน พ.ศ.)
                        </label>
                        <input type="date" id="letterDate" required onchange="updateThaiDateDisplay()" class="w-full bg-black/30 border border-white/20 rounded-2xl px-4 py-3 text-white focus:outline-none focus:border-emerald-400 focus:ring-2 focus:ring-emerald-500/20 transition-all">
                        <p id="thaiDateDisplay" class="text-xs text-emerald-300 mt-1.5 font-medium pl-1"></p>
                    </div>

                    <button type="submit" class="w-full bg-gradient-to-r from-emerald-500 to-green-600 hover:from-emerald-400 hover:to-green-500 text-white font-bold py-3.5 px-4 rounded-2xl shadow-xl transition-all duration-200 transform active:scale-[0.99] flex items-center justify-center gap-2 cursor-pointer mt-2">
                        <i class="fa-solid fa-floppy-disk"></i> บันทึกข้อมูลลง Google Sheet
                    </button>
                </form>
            </section>

            <section class="lg:col-span-7 glass-card rounded-3xl p-6 shadow-2xl flex flex-col justify-between overflow-hidden">
                <div class="space-y-4">
                    <div class="flex flex-wrap items-center justify-between gap-4 border-b border-white/10 pb-3">
                        <h2 class="text-lg font-bold flex items-center gap-2 text-emerald-300">
                            <i class="fa-solid fa-database"></i> รายการข้อมูลในระบบ
                        </h2>
                        <div class="flex items-center gap-2">
                            <button onclick="exportToExcel()" class="bg-emerald-700/50 hover:bg-emerald-700 border border-emerald-500/30 text-emerald-200 px-3 py-1.5 rounded-xl text-xs font-semibold transition-all flex items-center gap-1 cursor-pointer">
                                <i class="fa-solid fa-file-excel text-emerald-400"></i> Excel
                            </button>
                            <button onclick="exportToPDF()" class="bg-rose-700/50 hover:bg-rose-700 border border-rose-500/30 text-rose-200 px-3 py-1.5 rounded-xl text-xs font-semibold transition-all flex items-center gap-1 cursor-pointer">
                                <i class="fa-solid fa-file-pdf text-rose-400"></i> PDF
                            </button>
                        </div>
                    </div>

                    <div class="overflow-x-auto max-h-[520px] custom-scroll rounded-2xl border border-white/10 bg-black/20">
                        <table id="dataTable" class="w-full text-left border-collapse text-sm">
                            <thead>
                                <tr class="bg-white/10 sticky top-0 backdrop-blur-md text-emerald-200 border-b border-white/10">
                                    <th class="p-3.5 font-bold">โรงเรียน</th>
                                    <th class="p-3.5 font-bold text-center">มส.</th>
                                    <th class="p-3.5 font-bold">อาคารที่รื้อถอน</th>
                                    <th class="p-3.5 font-bold text-center">สถานะ</th>
                                    <th class="p-3.5 font-bold">เลขหนังสือ</th>
                                    <th class="p-3.5 font-bold">วันที่เอกสาร</th>
                                </tr>
                            </thead>
                            <tbody id="tableBody" class="divide-y divide-white/5">
                                <tr>
                                    <td colspan="6" class="p-8 text-center text-gray-400">
                                        <i class="fa-solid fa-spinner class animate-spin text-xl mb-2 text-emerald-400 block"></i>
                                        กำลังดาวน์โหลดข้อมูลล่าสุด...
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>

                <div class="text-xs text-emerald-200/50 mt-4 pt-3 border-t border-white/5 flex justify-between items-center">
                    <span>* ตารางใช้ระบบ scrolling เพื่อประหยัดพื้นที่หน้าจอ</span>
                    <span id="rowCount">รวม: 0 รายการ</span>
                </div>
            </section>
        </main>

        <div id="adminModal" class="fixed inset-0 bg-black/60 backdrop-blur-sm z-50 flex items-center justify-center p-4 hidden">
            <div class="glass-card rounded-3xl max-w-md w-full p-6 shadow-2xl space-y-4 border border-white/30 text-white">
                <h3 class="text-lg font-bold flex items-center gap-2 text-amber-300">
                    <i class="fa-solid fa-user-shield"></i> ตั้งค่าข้อมูลแอดมินและการแสดงผล
                </h3>
                <div class="space-y-3">
                    <div>
                        <label class="block text-xs font-semibold mb-1 text-gray-300">สำนักงานเขตพื้นที่การศึกษา</label>
                        <input type="text" id="input-office" value="ประถมศึกษาแม่ฮ่องสอน เขต 1" class="w-full bg-black/40 border border-white/20 rounded-xl px-3 py-2 text-sm focus:outline-none focus:border-amber-400">
                    </div>
                    <div>
                        <label class="block text-xs font-semibold mb-1 text-gray-300">ชื่อแอดมินผู้ดูแล</label>
                        <input type="text" id="input-admin" value="BABILLON Administrator" class="w-full bg-black/40 border border-white/20 rounded-xl px-3 py-2 text-sm focus:outline-none focus:border-amber-400">
                    </div>
                </div>
                <div class="flex justify-end gap-2 pt-2">
                    <button onclick="toggleAdminModal()" class="px-4 py-2 rounded-xl text-xs bg-white/10 hover:bg-white/20 transition-all cursor-pointer">ยกเลิก</button>
                    <button onclick="saveAdminSettings()" class="px-4 py-2 rounded-xl text-xs bg-amber-500 hover:bg-amber-400 font-bold transition-all cursor-pointer text-black">อัปเดตข้อมูล</button>
                </div>
            </div>
        </div>

        <footer class="text-center py-4 text-xs text-white/40 tracking-wider">
            © 2026 ผู้พัฒนา BABILLON - V.TEST 1
        </footer>
    </div>

    <script>
        // Configuration App Script Endpoint Connection
        const SCRIPT_URL = "https://script.google.com/macros/s/AKfycbx7T6dfEJToFJdlnIl2sjvD80ZsSZuuhK2dxXGcdYYMt7HQD3ym-hJ0IH-3gNH-pB7Siw/exec";
        let localDataStore = [];

        // App Initializer
        window.addEventListener('DOMContentLoaded', () => {
            generateBuildingOptions();
            initAdminData();
            loadData();
        });

        function initAdminData() {
            const office = localStorage.getItem('office') || "ประถมศึกษาแม่ฮ่องสอน เขต 1";
            const admin = localStorage.getItem('admin') || "เจ้าหน้าที่ดูแลงานพัสดุ";
            document.getElementById('display-office').innerText = office;
            document.getElementById('display-admin').innerText = admin;
            document.getElementById('input-office').value = office;
            document.getElementById('input-admin').value = admin;
        }

        function toggleAdminModal() {
            document.getElementById('adminModal').classList.toggle('hidden');
        }

        function saveAdminSettings() {
            const office = document.getElementById('input-office').value;
            const admin = document.getElementById('input-admin').value;
            localStorage.setItem('office', office);
            localStorage.setItem('admin', admin);
            initAdminData();
            toggleAdminModal();
            Swal.fire({ icon: 'success', title: 'อัปเดตข้อมูลแอดมินเสร็จสิ้น', toast: true, position: 'top-end', showConfirmButton: false, timer: 2000 });
        }

        function generateBuildingOptions() {
            const container = document.getElementById('buildingContainer');
            container.innerHTML = '';
            for(let i=1; i<=100; i++) {
                container.innerHTML += `
                    <label class="flex items-center gap-1.5 p-1.5 rounded-lg bg-white/5 hover:bg-white/10 text-xs cursor-pointer border border-white/5 transition-all">
                        <input type="checkbox" name="buildings" value="${i}" class="rounded bg-black/40 border-white/20 text-emerald-500 focus:ring-0">
                        <span>อาคาร ${i}</span>
                    </label>
                `;
            }
        }

        function updateThaiDateDisplay() {
            const dateInput = document.getElementById('letterDate').value;
            if(!dateInput) return;
            const dateObj = new Date(dateInput);
            const months = ["มกราคม", "กุมภาพันธ์", "มีนาคม", "เมษายน", "พฤษภาคม", "มิถุนายน", "กรกฎาคม", "สิงหาคม", "กันยายน", "ตุลาคม", "พฤศจิกายน", "ธันวาคม"];
            const day = dateObj.getDate();
            const month = months[dateObj.getMonth()];
            const yearBE = dateObj.getFullYear() + 543;
            document.getElementById('thaiDateDisplay').innerHTML = `<i class="fa-solid fa-circle-check"></i> ตรงกับ: วันที่ ${day} ${month} พ.ศ. ${yearBE}`;
        }

        function setSystemStatus(state) {
            const dot = document.getElementById('status-dot');
            const ping = document.getElementById('status-ping');
            const txt = document.getElementById('status-text');
            
            if(state === 'online') {
                dot.className = "relative inline-flex rounded-full h-3 w-3 bg-emerald-500";
                ping.className = "animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75";
                txt.innerText = "ออนไลน์";
                txt.className = "text-emerald-400";
            } else if(state === 'offline') {
                dot.className = "relative inline-flex rounded-full h-3 w-3 bg-rose-500";
                ping.className = "absolute inline-flex h-full w-full rounded-full bg-rose-400 opacity-0";
                txt.innerText = "ออฟไลน์";
                txt.className = "text-rose-400";
            } else {
                dot.className = "relative inline-flex rounded-full h-3 w-3 bg-yellow-500";
                ping.className = "animate-ping absolute inline-flex h-full w-full rounded-full bg-yellow-400 opacity-75";
                txt.innerText = "กำลังประมวลผล...";
                txt.className = "text-yellow-400";
            }
        }

        // Test API Connection
        function testConnection() {
            setSystemStatus('loading');
            fetch(`${SCRIPT_URL}?action=test`)
            .then(res => res.json())
            .then(data => {
                if(data.status === "success") {
                    setSystemStatus('online');
                    Swal.fire({ icon: 'success', title: 'เชื่อมต่อสำเร็จ!', text: 'ระบบสามารถสื่อสารกับ Google Sheet ได้ปกติ', confirmButtonColor: '#10b981' });
                }
            })
            .catch(err => {
                setSystemStatus('offline');
                Swal.fire({ icon: 'error', title: 'เชื่อมต่อล้มเหลว', text: 'ไม่สามารถติดต่อ Google App Script Web App ได้', confirmButtonColor: '#ef4444' });
            });
        }

        // Load Data Grid View
        function loadData() {
            setSystemStatus('loading');
            const body = document.getElementById('tableBody');
            
            fetch(`${SCRIPT_URL}?action=read`)
            .then(res => res.json())
            .then(data => {
                localDataStore = data;
                body.innerHTML = '';
                document.getElementById('rowCount').innerText = `รวม: ${data.length} รายการ`;
                
                if(data.length === 0) {
                    body.innerHTML = `<tr><td colspan="6" class="p-6 text-center text-gray-400">ยังไม่มีข้อมูลบันทึกในระบบ</td></tr>`;
                    setSystemStatus('online');
                    return;
                }

                data.forEach(row => {
                    let badgeColor = "bg-rose-500/20 text-rose-300 border-rose-500/30";
                    if(row.status === "✅เสร็จสิ้น") badgeColor = "bg-emerald-500/20 text-emerald-300 border-emerald-500/30";
                    if(row.status === "🕒กำลังดำเนินการ") badgeColor = "bg-amber-500/20 text-amber-300 border-amber-500/30";

                    body.innerHTML += `
                        <tr class="hover:bg-white/5 transition-colors">
                            <td class="p-3 font-semibold text-white">${row.school}</td>
                            <td class="p-3 text-center text-emerald-300 font-mono">${row.parcelNo}</td>
                            <td class="p-3 max-w-[180px] truncate text-gray-200" title="${row.buildings}">อาคาร ${row.buildings}</td>
                            <td class="p-3 text-center">
                                <span class="px-2 py-1 rounded-lg text-xs font-semibold border ${badgeColor}">${row.status}</span>
                            </td>
                            <td class="p-3 text-gray-300 font-mono text-xs">${row.letterNo}</td>
                            <td class="p-3 text-emerald-100 text-xs">${row.letterDate}</td>
                        </tr>
                    `;
                });
                setSystemStatus('online');
            })
            .catch(err => {
                setSystemStatus('offline');
                body.innerHTML = `<tr><td colspan="6" class="p-6 text-center text-rose-300">เกิดข้อผิดพลาดในการโหลดข้อมูล</td></tr>`;
            });
        }

        // Form Submit Handler
        function submitForm(e) {
            e.preventDefault();
            
            const school = document.getElementById('school').value;
            const parcelNo = document.getElementById('parcelNo').value;
            const letterNo = document.getElementById('letterNo').value;
            const letterDateInput = document.getElementById('letterDate').value;
            
            const selectedStatusEl = document.querySelector('input[name="status"]:checked');
            const status = selectedStatusEl ? selectedStatusEl.value : "";
            
            // Get Checked Buildings
            const checkedBuildings = [];
            document.querySelectorAll('input[name="buildings"]:checked').forEach(cb => {
                checkedBuildings.push(cb.value);
            });

            if(checkedBuildings.length === 0) {
                Swal.fire({ icon: 'warning', title: 'โปรดกรอกข้อมูลให้ครบ', text: 'กรุณาเลือก ลำดับอาคารที่ขอรื้อถอน อย่างน้อย 1 รายการ' });
                return;
            }

            // Convert Date to Thai Buddhist Year Display Format
            const dObj = new Date(letterDateInput);
            const thaiDateString = `${dObj.getDate()}/${dObj.getMonth()+1}/${dObj.getFullYear()+543}`;

            const payload = {
                school: school,
                parcelNo: parcelNo,
                buildings: checkedBuildings.join(', '),
                status: status,
                letterNo: letterNo,
                letterDate: thaiDateString,
                office: document.getElementById('display-office').innerText,
                admin: document.getElementById('display-admin').innerText
            };

            setSystemStatus('loading');
            Swal.fire({ title: 'กำลังส่งข้อมูล...', text: 'กรุณารอสักครู่ ระบบกำลังเขียนข้อมูลลงเซิร์ฟเวอร์', allowOutsideClick: false, didOpen: () => { Swal.showLoading(); } });

            fetch(SCRIPT_URL, {
                method: 'POST',
                mode: 'no-cors', // standard approach for google app script cross-domain post
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            })
            .then(() => {
                Swal.fire({ icon: 'success', title: 'บันทึกข้อมูลเรียบร้อย!', text: 'ระบบส่งข้อมูลขึ้น Google Sheet แล้ว', confirmButtonColor: '#10b981', timer: 3000 });
                document.getElementById('recordForm').reset();
                document.getElementById('letterNo').value = "ศธ 0415./";
                document.getElementById('thaiDateDisplay').innerText = '';
                generateBuildingOptions(); // reload items check box
                loadData(); // refresh grid view data table
            })
            .catch(err => {
                setSystemStatus('offline');
                Swal.fire({ icon: 'error', title: 'เกิดข้อผิดพลาด', text: 'ไม่สามารถส่งข้อมูลไปบันทึกได้' });
            });
        }

        // Export data directly to Excel Sheet Client Side
        function exportToExcel() {
            if(localDataStore.length === 0) {
                Swal.fire({ icon: 'info', title: 'ไม่พบข้อมูลในการดาวน์โหลด' });
                return;
            }
            
            const cleanRows = localDataStore.map(item => ({
                'โรงเรียน': item.school,
                'แปลงหมายเลขที่ มส.': item.parcelNo,
                'ลำดับอาคารที่ขอรื้อถอน': item.buildings,
                'สถานะการจัดส่งหนังสือ': item.status,
                'เลขหนังสือจากโรงเรียน': item.letterNo,
                'วันที่เอกสาร (พ.ศ.)': item.letterDate,
                'สำนักงานเขตพื้นที่': item.office,
                'ผู้บันทึกข้อมูล': item.admin,
                'วันเวลาทำรายการ': item.timestamp
            }));

            const ws = XLSX.utils.json_to_sheet(cleanRows);
            const wb = XLSX.utils.book_new();
            XLSX.utils.book_append_sheet(wb, ws, "รายงานสถานะที่ราชพัสดุ");
            XLSX.writeFile(wb, `รายงานที่ราชพัสดุ_และพื้นที่ป่าไม้_${new Date().toISOString().slice(0,10)}.xlsx`);
        }

        // Export Table View to PDF Report
        function exportToPDF() {
            if(localDataStore.length === 0) {
                Swal.fire({ icon: 'info', title: 'ไม่พบข้อมูลในการดาวน์โหลด' });
                return;
            }

            const element = document.createElement('div');
            element.className = "p-8 text-black bg-white space-y-6";
            element.style.fontFamily = "'Sarabun', sans-serif";
            
            const officeName = document.getElementById('display-office').innerText;
            
            element.innerHTML = `
                <div style="text-align: center; margin-bottom: 20px;">
                    <h2 style="font-size: 18px; font-weight: bold; margin: 0;">รายงานสถานะที่ราชพัสดุและพื้นที่ป่าไม้ฯ</h2>
                    <p style="font-size: 14px; margin: 5px 0;">สำนักงานเขตพื้นที่การศึกษา ${officeName}</p>
                    <p style="font-size: 11px; color: #555;">ส่งออกข้อมูล ณ วันที่: ${new Date().toLocaleDateString('th-TH')}</p>
                </div>
                <table style="width: 100%; border-collapse: collapse; font-size: 11px;">
                    <thead>
                        <tr style="background-color: #f3f4f6; border-top: 1px solid #000; border-bottom: 1px solid #000;">
                            <th style="padding: 8px; text-align: left;">โรงเรียน</th>
                            <th style="padding: 8px; text-align: center;">หมายเลข มส.</th>
                            <th style="padding: 8px; text-align: left;">ลำดับอาคาร</th>
                            <th style="padding: 8px; text-align: center;">สถานะ</th>
                            <th style="padding: 8px; text-align: left;">เลขหนังสือ</th>
                            <th style="padding: 8px; text-align: center;">วันที่เอกสาร</th>
                        </tr>
                    </thead>
                    <tbody>
                        ${localDataStore.map(row => `
                            <tr style="border-bottom: 1px solid #e5e7eb;">
                                <td style="padding: 8px;">${row.school}</td>
                                <td style="padding: 8px; text-align: center;">${row.parcelNo}</td>
                                <td style="padding: 8px;">อาคาร ${row.buildings}</td>
                                <td style="padding: 8px; text-align: center;">${row.status}</td>
                                <td style="padding: 8px;">${row.letterNo}</td>
                                <td style="padding: 8px; text-align: center;">${row.letterDate}</td>
                            </tr>
                        `).join('')}
                    </tbody>
                </table>
                <div style="margin-top: 30px; font-size: 10px; text-align: right; color: #666;">
                    ดึงข้อมูลโดยระบดูแลระบบสารสนเทศ BABILLON V.TEST 1
                </div>
            `;

            const opt = {
                margin:       [10, 10, 10, 10],
                filename:     `รายงานที่ราชพัสดุ_${new Date().toISOString().slice(0,10)}.pdf`,
                image:        { type: 'jpeg', quality: 0.98 },
                html2canvas:  { scale: 2 },
                jsPDF:        { unit: 'mm', format: 'a4', orientation: 'landscape' }
            };

            html2pdf().set(opt).from(element).save();
        }
    </script>
</body>
</html>
